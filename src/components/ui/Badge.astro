---
/**
 * Badge — small label for tags, labels, or status indicators.
 */
interface Props {
  variant?: 'default' | 'brand' | 'ok' | 'warn';
  class?: string;
}

const { variant = 'default', class: className = '' } = Astro.props;

const variants = {
  default: 'bg-surface-2 text-ink-3 border border-line',
  brand: 'bg-brand-soft text-brand border border-brand/20',
  ok: 'bg-ok/10 text-ok border border-ok/20',
  warn: 'bg-warn/10 text-warn border border-warn/20',
};
---

<span
  class={`inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-medium ${variants[variant]} ${className}`}
>
  <slot />
</span>
