---
/**
 * ThemeToggle — accessible dark/light appearance switcher.
 *
 * - Sun icon in dark mode (click → light), moon icon in light mode (click → dark)
 * - Persists choice in localStorage('theme')
 * - Falls back to prefers-color-scheme on first visit
 * - No FOUC: the no-FOUC script in BaseLayout sets .dark before paint;
 *   this toggle only reads/writes the state
 * - Vanilla JS (no React island) — minimal payload
 * - aria-label updates dynamically; aria-pressed reflects state
 * - Keyboard accessible (it's a <button>)
 */
---

<button
  id="theme-toggle"
  type="button"
  class="inline-flex h-9 w-9 items-center justify-center rounded-md text-ink-3 hover:bg-surface-2 hover:text-brand transition-colors focus-visible:outline-2 focus-visible:outline-brand focus-visible:outline-offset-2"
  aria-label="Switch to dark theme"
  aria-pressed="false"
  title="Toggle theme"
>
  {/* Moon icon (shown in light mode — click to go dark) */}
  <svg
    class="theme-icon-moon"
    width="20"
    height="20"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.75"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
  </svg>

  {/* Sun icon (shown in dark mode — click to go light) */}
  <svg
    class="theme-icon-sun hidden"
    width="20"
    height="20"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.75"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4"></circle>
    <path
      d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"
    ></path>
  </svg>
</button>

<script>
  (function () {
    var toggleEl = document.getElementById('theme-toggle');
    if (!toggleEl) return;
    var toggle = toggleEl;

    var moonIcon = toggle.querySelector('.theme-icon-moon');
    var sunIcon = toggle.querySelector('.theme-icon-sun');

    function isDark() {
      return document.documentElement.classList.contains('dark');
    }

    function updateUI() {
      var dark = isDark();
      // Show sun in dark mode, moon in light mode
      if (moonIcon) moonIcon.classList.toggle('hidden', dark);
      if (sunIcon) sunIcon.classList.toggle('hidden', !dark);
      toggle.setAttribute(
        'aria-label',
        dark ? 'Switch to light theme' : 'Switch to dark theme',
      );
      toggle.setAttribute('aria-pressed', String(dark));
    }

    // Sync UI with the state set by the no-FOUC script
    updateUI();

    toggle.addEventListener('click', function () {
      var dark = !isDark();
      document.documentElement.classList.toggle('dark', dark);
      try {
        localStorage.setItem('theme', dark ? 'dark' : 'light');
      } catch (e) {
        /* ignore localStorage errors */
      }
      updateUI();

      // Update the <meta name="theme-color"> to match
      var meta = document.querySelector('meta[name="theme-color"]');
      if (meta) {
        meta.setAttribute('content', dark ? '#0b0f1a' : '#1b4dff');
      }
    });

    // Sync with system preference changes (only if user hasn't set a preference)
    try {
      var stored = localStorage.getItem('theme');
      if (!stored) {
        var mq = window.matchMedia('(prefers-color-scheme: dark)');
        mq.addEventListener('change', function (e) {
          document.documentElement.classList.toggle('dark', e.matches);
          updateUI();
        });
      }
    } catch (e) {
      /* ignore */
    }
  })();
</script>
